# ===== 필수: 비밀키 (기본값 없음) =====
# 텍스트·이미지·가이드(LLM) 호출
OPENAI_API_KEY=

# ===== translation 라이브 (mock=false) =====
# KURE 임베딩 다운로드용. 보통 비워도 됨.
HF_TOKEN=
# self-host Qdrant URL. 비우면 임베디드(path=) 폴백.
# 배포(compose)는 http://qdrant:6333.
QDRANT_URL=
# kculture 문화 각주 검색 임계치(코사인).
WLIGHTER_ANNOTATION_SCORE_THRESHOLD=0.55

# ===== 요청 제한 =====
# API 요청 JSON body 전체 크기 제한. 기본 512KB.
MAX_REQUEST_BODY_BYTES=524288

# ===== LLM 호출 제어 (레이트리밋) =====
# 번역 1건 내부 fan-out(리뷰 4노드 등) 동시 LLM 호출 상한. LangGraph 동기 invoke가 스레드풀로 병렬 실행.
# CONCURRENCY의 경우, 현 번역 단계에서 최대 병렬 작업 수가 4. 호출 빈도가 빈번하다고 판단되면 2~3으로 축소.
WLIGHTER_LLM_MAX_CONCURRENCY=4
# OpenAI SDK 내장 재시도 횟수(429/5xx/연결오류 지수 백오프). 호출 1건당 독립 적용.
WLIGHTER_OPENAI_MAX_RETRIES=5
# OpenAI 호출 1건당 타임아웃(초). 개별 호출 기준 (한자/태국어의 경우 출력이 오래 걸릴 수 있어 120초 설정).
WLIGHTER_OPENAI_TIMEOUT=120

# ===== 모델 (기본값 있음 — 바꿀 때만 설정) =====
# 텍스트(채팅) 기본 모델 — translation/character/relationship 등.
WLIGHTER_TEXT_MODEL=gpt-5.4-mini
# 가이드 LLM 기본 모델. 코드 기본값도 gpt-5.4-mini지만, Docker/서버 .env 누락 혼선을 줄이기 위해 명시.
WLIGHTER_GUIDE_MODEL=gpt-5.4-mini
# 이미지(cover) 생성.
WLIGHTER_IMAGE_MODEL=gpt-image-2
WLIGHTER_IMAGE_SIZE=1024x1536
WLIGHTER_IMAGE_QUALITY=medium
WLIGHTER_IMAGE_FORMAT=png

# ===== 동작 토글 =====
# true면 키/Qdrant 없이 결정적 mock.
WLIGHTER_MOCK_MODE=false
# 가이드는 기본 LLM-first. false(0)로 설정할 때만 LLM 가이드 생성을 비활성화.
WLIGHTER_GUIDE_LLM=true
# startup에 KURE/파이프라인 1회 적재. prod는 1 권장(콜드스타트 방지), dev/CI는 false(빠른 부팅).
WARMUP_ON_STARTUP=false

# ===== 저장소 백엔드 =====
# 콘텐츠 영속화(works/episodes/characters/translation_results).
#   rdb(기본) = 로컬은 DATABASE_URL 비우면 SQLite 폴백. 배포 시 DATABASE_URL를 MySQL로.
#   memory   = 인메모리(휘발). 테스트/CI는 SQLite 파일 오염 방지 위해 memory 사용.
CONTENT_STORE_BACKEND=rdb
# rdb일 때 연결 URL. 비우면 로컬 SQLite.
DATABASE_URL=

# glossary 저장소는 DATABASE_URL(또는 MYSQL_*) 접속 가능하면 MySQL, 아니면 in-memory로 **자동 결정**.
#   ★GLOSSARY_STORE_BACKEND 토글은 더 이상 사용하지 않음(무시). 아래 줄은 구버전 호환용 — 안 적어도 되고,
#    옛 .env에 GLOSSARY_STORE_BACKEND=memory 가 남아 있어도 이제 무시되므로 dedup이 정상 동작.
GLOSSARY_STORE_BACKEND=mysql
# (선택) glossary를 DATABASE_URL과 다른 DB로 보내고 싶을 때만 채움 — override:
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# ===== S3 표지 이미지 저장 =====
# EC2 IAM Role 방식이면 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY 필요 없음.
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=
AWS_S3_BASE_URL=
# 표지 이미지 S3 key prefix. 기본 covers.
AWS_S3_COVER_PREFIX=covers
# private 버킷 미리보기용 presigned URL 만료 초. 기본 3600초.
AWS_S3_PRESIGNED_EXPIRES=3600
RATE_LIMIT_ENABLED=true

ENABLE_DOCS=true
